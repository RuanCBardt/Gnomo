{
  "name": "gnomo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler pages dev dist --proxy 5173",
    "dev:full": "concurrently -n \"vite,worker\" -c \"cyan,magenta\" \"vite\" \"wrangler pages dev dist --proxy 5173\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tailwindcss/vite": "^4.2.1",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.0.0",
    "wrangler": "^4.75.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vueuse/core": "^14.2.1",
    "chart.js": "^4.5.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "uuid": "^13.0.0",
    "vue": "^3.5.30",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  }
}
